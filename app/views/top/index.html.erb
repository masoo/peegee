<%# ====================== HERO ====================== %>
<section class="hero-block" id="generator">
  <span class="chip"><span class="dot"></span>Generated in your browser · never sent anywhere</span>

  <h1 class="hero">
    Strong passwords,<br>
    <span class="muted">without the fuss.</span>
  </h1>
  <p class="lede">
    Peegee generates strong, unique passwords for any site — and quietly handles
    the awkward rules of Japanese services that other generators don't.
  </p>

  <%# Mode segmented control (real radio inputs) %>
  <form class="segments" role="radiogroup" aria-label="Password mode">
    <input type="radio" name="mode" id="m-standard"  value="standard"  checked>
    <label for="m-standard">Standard</label>
    <input type="radio" name="mode" id="m-japanese"  value="japanese">
    <label for="m-japanese">Japanese</label>
  </form>

  <article class="pw-card">
    <div class="pw-card-body">
      <div style="flex:1; min-width:0;">
        <output id="pw-output" class="pw-display" aria-live="polite">…</output>
        <div class="strength" aria-label="Password strength">
          <div class="bars" id="pw-bars">
            <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
          </div>
          <strong id="pw-label">—</strong>
          <small>· 10^<span id="pw-guesses">0</span> guesses</small>
        </div>
      </div>
      <div class="pw-actions">
        <button class="secondary outline" id="btn-regen" type="button">
          <span aria-hidden="true">↻</span> Regenerate
        </button>
        <button class="primary" id="btn-copy" type="button">
          <span aria-hidden="true">⧉</span> <span id="btn-copy-label">Copy</span>
        </button>
      </div>
    </div>
  </article>
</section>

<%# ====================== LOCALIZED FOR JAPAN ====================== %>
<section class="block" id="sites">
  <div class="page" style="padding:0;">
    <div class="sites-head">
      <div>
        <div class="eyebrow">Localized for Japan</div>
        <h2 style="margin:0; font-size:2rem; line-height:1.1; letter-spacing:-0.025em;">Tuned to each service's quirks</h2>
      </div>
    </div>

    <div class="sites-grid" id="sites-top"></div>

    <details class="more-sites">
      <summary class="toggle" role="button">
        <span class="when-closed">Show all 6</span>
        <span class="when-open">Show less</span>
        <svg width="12" height="12" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </summary>
      <div class="more-grid" id="sites-extra"></div>
    </details>
  </div>
</section>

<%# ====================== MCP ====================== %>
<section class="block surface" id="mcp">
  <div class="page" style="padding:0;">
    <div class="two-col">
      <div>
        <div class="eyebrow">For AI assistants · MCP</div>
        <h2>Let your AI assistant generate passwords for you.</h2>
        <p>
          Peegee runs as a remote MCP server. Connect it once and Claude
          Code, Cursor, or VS Code can call any generator on demand — no API
          keys, no setup beyond a single command.
        </p>

        <div class="tools-list">
          <div class="label">Available tools</div>
          <ul>
            <li><span class="name">generate_standard_password</span><span class="dots"></span><span class="desc">Strong random</span></li>
            <li><span class="name">generate_japanese_secret_question</span><span class="dots"></span><span class="desc">Hiragana</span></li>
            <li><span class="name">generate_kuroneko_password</span><span class="dots"></span><span class="desc">Yamato members</span></li>
            <li><span class="name">generate_nenkin_password</span><span class="dots"></span><span class="desc">Pension service</span></li>
            <li><span class="name">generate_sbisec_password</span><span class="dots"></span><span class="desc">Securities</span></li>
          </ul>
        </div>
      </div>

      <div>
        <form class="mcp-tabs" role="radiogroup" aria-label="MCP client">
          <input type="radio" name="client" id="c-claude" value="claude" checked>
          <label for="c-claude">Claude Code</label>
          <input type="radio" name="client" id="c-vscode" value="vscode">
          <label for="c-vscode">VS Code</label>
          <input type="radio" name="client" id="c-cursor" value="cursor">
          <label for="c-cursor">Cursor</label>
        </form>

        <pre class="code-block" data-mcp-url="<%= request.base_url %>/mcp/sse"><code id="mcp-code"></code>
<button class="copy" id="mcp-copy" type="button">Copy</button></pre>

        <div class="hint-row">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2"/>
            <path d="M8 5v3.5M8 11v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          </svg>
          <span id="mcp-hint">Restart Claude Code after running the command.</span>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ====================== DEVELOPERS ====================== %>
<section class="block surface" id="developers">
  <div class="page" style="padding:0;">
    <div class="two-col">
      <div>
        <div class="eyebrow">For developers</div>
        <h2>One endpoint away from a fresh password.</h2>
        <p>
          Plain TXT or JSON over HTTPS. No keys, no quotas — just hit the
          endpoint from your shell, your script, or your CI.
        </p>
      </div>
      <div class="endpoints">
        <div class="row">
          <span class="method">GET</span>
          <span class="path"><%= g_index_path(format: :json) %></span>
          <span class="desc">Standard password</span>
        </div>
        <div class="row">
          <span class="method">GET</span>
          <span class="path"><%= japanese_secret_questions_path(format: :json) %></span>
          <span class="desc">Japanese hiragana</span>
        </div>
        <div class="row">
          <span class="method">GET</span>
          <span class="path"><%= sbisec_co_jp_path(format: :json) %></span>
          <span class="desc">SBI Securities</span>
        </div>
      </div>
    </div>
  </div>
</section>

